APP_NAME=safe-ingestion-engine
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=sqlite:///./data/jobs.db
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

PII_SALT=replace-with-32-char-minimum-secret-value
API_KEY_SALT=replace-with-32-char-minimum-secret-value
DASHBOARD_ADMIN_PASSWORD=replace-with-12-char-minimum
API_KEY_HASHES_JSON=["replace-with-hmac-api-key-hash"]

REQUEST_TIMEOUT_SECONDS=10
MAX_RESPONSE_BYTES=5242880
ROBOTS_ERROR_MODE=deny
ALLOW_REDIRECTS=false
RATE_LIMIT_PER_MINUTE=10
CORS_ORIGINS_JSON=["http://localhost:3000"]
