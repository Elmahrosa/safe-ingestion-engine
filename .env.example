# ── Required ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
DATA_DIR=data

# ── Apps Script billing (v2) — get these after deploying safeteosegypt_FINAL.gs
SHEET_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_V2_DEPLOYMENT_ID/exec
SHEET_API_SECRET=CHANGE-THIS-TO-RANDOM-32-CHAR-SECRET

# ── Security ──────────────────────────────────────────────────────────────────
PII_SALT=change-this-random-salt-32-chars
DASHBOARD_ADMIN_PASSWORD=change-this-strong-password

# ── Optional ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://safe.teosegypt.com
USER_AGENT=SafeIngestion/1.0
REQUIRE_PAYMENT=false
TEOS_MODE=production
