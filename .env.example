
# ============================================================================
# Safe Ingestion Engine — Environment Configuration
# This file is an example template.
# Copy to `.env` and replace placeholder values with real secrets.
# ============================================================================

# ── Core System ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
DATA_DIR=data

# ── Apps Script Billing (v2) ────────────────────────────────────────────────
# After deploying safeteosegypt_FINAL.gs you will receive the deployment URL
SHEET_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Secret shared between API and Google Apps Script
SHEET_API_SECRET=CHANGE_THIS_TO_RANDOM_32_CHAR_SECRET


# ── Security ────────────────────────────────────────────────────────────────

# Used for deterministic hashing of detected PII
PII_SALT=CHANGE_THIS_TO_RANDOM_32_CHAR_SALT

# Dashboard admin login password
DASHBOARD_ADMIN_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD


# ── API Configuration ───────────────────────────────────────────────────────

# Allowed frontend origins
CORS_ORIGINS=https://safe.teosegypt.com

# HTTP user agent used by scraper
USER_AGENT=SafeIngestion/1.0

# Require payment validation before ingestion
REQUIRE_PAYMENT=false


# ── Runtime Mode ────────────────────────────────────────────────────────────

# development | staging | production
TEOS_MODE=production


# ── Security Hardening ──────────────────────────────────────────────────────

# Prevent open redirect attacks during scraping
ALLOW_REDIRECTS=false


# ── Optional Debugging ──────────────────────────────────────────────────────

# Enable verbose logging
LOG_LEVEL=INFO
