from fastapi.testclient import TestClient

from api.main import app
from tests.conftest import TEST_API_KEY

client = TestClient(app)

def test_ingest_requires_api_key():
    response = client.post("/v1/ingest", json={"url": "https://example.com"})
    assert response.status_code == 422

def test_ingest_rejects_invalid_key():
    response = client.post("/v1/ingest", json={"url": "https://example.com"}, headers={"X-API-Key": "bad"})
    assert response.status_code == 401

def test_ingest_accepts_valid_key(monkeypatch):
    class DummyTask:
        id = "job-123"
    def fake_delay(url, api_key):
        return DummyTask()
    monkeypatch.setattr("infrastructure.queue.tasks.ingest_url_task.delay", fake_delay)
    response = client.post("/v1/ingest", json={"url": "https://example.com"}, headers={"X-API-Key": TEST_API_KEY})
    assert response.status_code == 200
    assert response.json()["job_id"] == "job-123"
